{
  "manifest_version": 3,
  "name": "Screen Time Tamagotcha",
  "version": "1.0",
  "description": "Keep your digital pet healthy by staying focused and limiting screen time on distracting sites.",
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Screen Time Tamagotcha",
    "default_icon": {
      "16": "assets/icon.png",
      "48": "assets/icon.png",
      "128": "assets/icon.png"
    }
  },
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "options_page": "options.html"
}
